# ─────────────────────────────────────────────────────────────────────────
#  Supabase — copy this file to `.env.local` and fill in your project values.
#  Project Settings → API in the Supabase dashboard.
# ─────────────────────────────────────────────────────────────────────────

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / publishable API key. Safe to expose to the browser — every request
# is still gated by Row Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role / secret key — SERVER ONLY, never exposed to the browser.
# Used by server actions for OTP sign-in and to provision the admin account.
SUPABASE_SERVICE_ROLE_KEY=

# When not "false", phone OTP codes are shown on screen instead of sent by SMS
# (useful before configuring an SMS provider). Set to "false" in production.
OTP_TEST_MODE=true

# Admin panel credentials (username + password login at /admin).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
